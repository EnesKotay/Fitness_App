############################################################
# FitMentor Backend — Production Ortam Değişkenleri
# Bu dosyayı kopyala: cp .env.example .env
# .env dosyasını asla commit'leme!
############################################################

# ── DATABASE ─────────────────────────────────────────────
# Railway: Settings > Variables > DATABASE_URL formatı:
#   postgresql://user:password@host:port/dbname
# jdbc: prefix'i Quarkus için ekle:
DB_URL=jdbc:postgresql://your-host:5432/your-db
DB_USERNAME=your-db-user
DB_PASSWORD=your-strong-password-here

# ── JWT ──────────────────────────────────────────────────
# En az 64 karakter, rastgele üret:
#   openssl rand -base64 64
JWT_SECRET_KEY=replace-with-64-char-random-secret

# ── AI KEYS ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
CLAUDE_API_KEY=your-claude-api-key

# ── IN-APP PURCHASE ───────────────────────────────────────
# App Store Connect > My Apps > Subscriptions > Shared Secret
IAP_APPLE_SHARED_SECRET=your-apple-shared-secret
IAP_APPLE_BUNDLE_ID=com.fitnessapp.tracker
IAP_APPLE_SANDBOX=false
IAP_VERIFY_MODE=strict

# Google Play Console > Setup > API Access > Service Account
# JSON dosyasını tek satıra: jq -c . service-account.json
IAP_GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
IAP_GOOGLE_PACKAGE_NAME=com.fitnessapp.tracker

# ── EMAIL (Gmail App Password) ────────────────────────────
# Gmail > Google Account > Security > 2FA > App Passwords
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=noreply@fitnessapp.com
MAIL_MOCK=false

# ── QUARKUS PROFILE ───────────────────────────────────────
QUARKUS_PROFILE=prod

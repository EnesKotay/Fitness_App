# Backend Ortam Değişkenleri (Production)
# Bu dosyayı .env olarak kopyala ve gerçek değerleri yaz.
# .env dosyası .gitignore'da olduğu için repo'ya commit edilmez.
#
# ÖNEMLI: Aşağıdaki değerlerin hepsi production'da gerçek değerlerle değiştirilmeli!

MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_MOCK=false

GEMINI_API_KEY=your-gemini-api-key
CLAUDE_API_KEY=your-claude-api-key
DB_PASSWORD=your-strong-db-password

# JWT Secret (en az 64 karakter, SecureRandom ile oluşturulmalı)
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_SECRET_USE_OPENSSL_RAND_BASE64_48

# IAP (In-App Purchase) — Production ayarları
IAP_VERIFY_MODE=strict
IAP_APPLE_SHARED_SECRET=your-apple-shared-secret
IAP_APPLE_BUNDLE_ID=com.fitnessapp.tracker
IAP_APPLE_SANDBOX=false
IAP_GOOGLE_PACKAGE_NAME=com.fitnessapp.tracker
IAP_GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

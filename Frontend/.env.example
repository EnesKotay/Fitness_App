############################################################
# FitMentor Flutter — Build-Time Dart Define Değerleri
# Bu dosyayı commit'leme. Build komutlarında --dart-define kullan.
############################################################

# ── BACKEND API ───────────────────────────────────────────
API_BASE_URL=https://api.seninadrsin.com

# ── SENTRY ────────────────────────────────────────────────
# sentry.io > Projects > DSN
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# ── LEGAL URLS ────────────────────────────────────────────
APP_PRIVACY_URL=https://seninadrsin.com/privacy
APP_TERMS_URL=https://seninadrsin.com/terms
APP_SUPPORT_URL=https://seninadrsin.com/support
APP_PRIVACY_EMAIL=privacy@fitmentor.app
APP_LEGAL_EMAIL=legal@fitmentor.app

############################################################
# Kullanım:
#   flutter build ipa \
#     --dart-define=API_BASE_URL=https://api.seninadrsin.com \
#     --dart-define=SENTRY_DSN=https://... \
#     --dart-define=APP_PRIVACY_URL=https://seninadrsin.com/privacy \
#     --dart-define=APP_TERMS_URL=https://seninadrsin.com/terms \
#     --dart-define=APP_SUPPORT_URL=https://seninadrsin.com/support
############################################################
